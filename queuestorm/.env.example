# Primary (per spec) — set to your AISA/OpenAI key
OPENAI_API_KEY=

# Fallback — used if OPENAI_API_KEY is unset
AISA_API_KEY=

# Override base URL for OpenAI-compatible gateways (e.g. AISA)
AISA_BASE_URL=https://api.aisa.one/v1

# Model name to call (must be available on the configured base URL)
MODEL_NAME=gpt-4o-mini

PORT=8000